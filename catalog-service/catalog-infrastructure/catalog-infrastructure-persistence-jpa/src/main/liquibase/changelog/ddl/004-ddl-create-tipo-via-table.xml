<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

    <changeSet id="004-create-tipo-via-table" author="liquibase" labels="ddl">
        <createTable tableName="TIPO_VIA">
            <column name="ID" type="VARCHAR(2)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="CLAVE" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="DENOMINACION" type="VARCHAR(50)">
                <constraints nullable="true"/>
            </column>
        </createTable>
        
        <rollback>
            <dropTable tableName="TIPO_VIA"/>
        </rollback>
    </changeSet>

</databaseChangeLog>