<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

    <changeSet id="102-load-provincia-data" author="liquibase" labels="data,dml">
        <comment>Carga inicial de provincias desde archivo CSV</comment>
        
        <loadData
            file="./data/provincias.csv"
            tableName="PROVINCIA"
            separator=","
            quotchar='"'
            encoding="UTF-8">
            
            <column name="ID" type="STRING"/>
            <column name="DENOMINACION" type="STRING"/>
            <column name="CA_ID" type="STRING"/>
        </loadData>

        <rollback>
            <delete tableName="PROVINCIA"/>
        </rollback>
    </changeSet>

</databaseChangeLog>