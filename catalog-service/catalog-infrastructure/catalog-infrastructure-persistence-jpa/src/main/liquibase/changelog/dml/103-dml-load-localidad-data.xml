<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

    <changeSet id="103-load-localidad-data" author="liquibase" labels="data,dml">
        <comment>Load localidad data from CSV file</comment>
        
        <loadData
            file="./data/localidades.csv"
            tableName="LOCALIDAD"
            separator=","
            quotchar='"'
            encoding="UTF-8">
            
            <column name="PROVINCIA_ID" type="STRING"/>
            <column name="ID" type="STRING"/>
            <column name="DENOMINACION" type="STRING"/>
        </loadData>

        <rollback>
            <delete tableName="LOCALIDAD"/>
        </rollback>
    </changeSet>

</databaseChangeLog>